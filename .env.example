# ============================================================================
# mcp-vision-server 环境变量配置示例
# 复制为 .env 或在 MCP 客户端 env 字段中使用
# ============================================================================

# ---------------------------------------------------------------------------
# 方式一：供应商预设（推荐，一键切换）
# ---------------------------------------------------------------------------
VISION_PROVIDER=zhipu
VISION_API_KEY=your_api_key_here

# ---------------------------------------------------------------------------
# 所有可用供应商预设
# ---------------------------------------------------------------------------
# 智谱 GLM
# VISION_PROVIDER=zhipu
# VISION_API_KEY=your_zhipu_key
# ZHIPU_API_KEY=your_zhipu_key          # 专属环境变量（兜底）

# 阿里百炼（通义千问 VL）
# VISION_PROVIDER=bailian
# VISION_API_KEY=your_dashscope_key
# DASHSCOPE_API_KEY=your_dashscope_key  # 专属环境变量

# DeepSeek
# VISION_PROVIDER=deepseek
# VISION_API_KEY=sk-your_deepseek_key
# DEEPSEEK_API_KEY=sk-xxx

# OpenAI
# VISION_PROVIDER=openai
# VISION_API_KEY=sk-your_openai_key
# OPENAI_API_KEY=sk-xxx

# SiliconFlow（聚合平台，支持 Qwen-VL 等）
# VISION_PROVIDER=siliconflow
# VISION_API_KEY=sk-your_siliconflow_key
# SILICONFLOW_API_KEY=sk-xxx

# OpenRouter（聚合平台）
# VISION_PROVIDER=openrouter
# VISION_API_KEY=sk-your_openrouter_key
# OPENROUTER_API_KEY=sk-xxx

# 火山方舟（豆包 Vision）
# VISION_PROVIDER=ark
# VISION_API_KEY=your_ark_key
# ARK_API_KEY=your_ark_key

# 阶跃星辰
# VISION_PROVIDER=stepfun
# VISION_API_KEY=your_stepfun_key
# STEPFUN_API_KEY=your_stepfun_key

# Kimi（月之暗面）
# VISION_PROVIDER=kimi
# VISION_API_KEY=sk-your_kimi_key
# MOONSHOT_API_KEY=sk-xxx

# MiniMax
# VISION_PROVIDER=minimax
# VISION_API_KEY=your_minimax_key
# MINIMAX_API_KEY=your_minimax_key

# ModelScope（魔搭社区）
# VISION_PROVIDER=modelscope
# VISION_API_KEY=your_modelscope_key
# MODELSCOPE_API_KEY=your_modelscope_key

# NVIDIA NIM
# VISION_PROVIDER=nvidia
# VISION_API_KEY=nvapi-your_nvidia_key
# NVIDIA_API_KEY=nvapi-xxx

# Novita AI
# VISION_PROVIDER=novita
# VISION_API_KEY=your_novita_key
# NOVITA_API_KEY=your_novita_key

# ---------------------------------------------------------------------------
# 方式二：完全手动指定（不依赖预设）
# ---------------------------------------------------------------------------
# VISION_BASE_URL=https://your-custom-endpoint/v1
# VISION_API_KEY=your_key
# VISION_MODEL=your-model-name

# ---------------------------------------------------------------------------
# 覆盖供应商默认值（可选，与预设配合使用）
# ---------------------------------------------------------------------------
# VISION_MODEL=gpt-4o-mini              # 覆盖预设的默认模型
# VISION_BASE_URL=https://proxy.example.com/v1  # 覆盖预设的端点