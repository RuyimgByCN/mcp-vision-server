# 多供应商 vision MCP —— 环境变量示例
# 复制为 .env 或在 MCP 客户端的 env 字段里填这些值。

# 【推荐】选择供应商 (zhipu/bailian/deepseek/openai/siliconflow/openrouter/ark/stepfun/kimi/minimax/modelscope/nvidia/novita)
VISION_PROVIDER=zhipu

# 【必填】通用 API key 环境变量 (优先级最高)
VISION_API_KEY=your_api_key_here

# 或者用供应商专属环境变量 (兜底)
# ZHIPU_API_KEY=...
# DASHSCOPE_API_KEY=...
# DEEPSEEK_API_KEY=...
# OPENAI_API_KEY=...

# 覆盖供应商默认模型 (可选)
# VISION_MODEL=qwen-vl-max

# 覆盖供应商默认端点 (可选)
# VISION_BASE_URL=https://your-custom-endpoint/v1